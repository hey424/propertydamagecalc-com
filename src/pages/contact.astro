---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Contact | propertydamagecalc.com';
const description = 'Contact the editorial team at propertydamagecalc.com with corrections, feedback, or questions about property damage claims content.';
---
<BaseLayout title={title} description={description}>
  <h1>Contact</h1>
  <p>For corrections, feedback, or questions about our content, email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>

  <h2>What We Can Help With</h2>
  <ul>
    <li><strong>Corrections:</strong> If you find a factual error — wrong depreciation rate, outdated state statute, incorrect description of the 17c formula, misstated coverage rule — let us know with a description of the error and a reference to the correct authority.</li>
    <li><strong>Feedback:</strong> Suggestions for additional guides, new calculator features, or topics we haven't covered.</li>
    <li><strong>Media inquiries:</strong> Reporters, researchers, or educators who want to reference our calculator methodology or guides.</li>
  </ul>

  <h2>What We Can't Help With</h2>
  <p>We are not able to provide advice about specific claims, specific policies, or specific adjustment disputes. We are an editorial and educational resource, not an insurance company, public adjuster, or law firm. For help with a significant first-party insurance claim, consider a licensed public adjuster. For third-party negligence or property damage litigation, consult a licensed property damage or personal injury attorney. Many property damage attorneys offer free consultations.</p>

  <p>Our typical response time for correction requests is 2–5 business days.</p>
</BaseLayout>
