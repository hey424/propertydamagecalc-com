---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Guides | propertydamagecalc.com';
const description = 'In-depth guides covering key topics at propertydamagecalc.com.';
---
<BaseLayout title={title} description={description}>
  <h1>Guides</h1>
  <p>Plain-language guides written and reviewed by our editorial team.</p>
  <h3><a href="/guides/how-property-damage-claims-work">How Property Damage Claims Work</a></h3>
  <p>First-party vs. third-party claims, the valuation process, depreciation disputes, and total loss procedures.</p>
  <h3><a href="/guides/rcv-vs-acv">RCV vs. ACV Explained</a></h3>
  <p>The critical difference between replacement cost value and actual cash value, and how it affects your payout.</p>
  <h3><a href="/guides/diminished-value-claims">Diminished Value Claims</a></h3>
  <p>How to calculate and claim diminished value for a repaired vehicle after an accident.</p>
  <h3><a href="/guides/property-damage-misconceptions">Common Property Damage Misconceptions</a></h3>
  <p>Common misunderstandings about property damage claims, ACV deductions, flood exclusions, and diminished value.</p>
  <ul style="margin-top:2rem">
    <li><a href="/case-types">Case types overview</a></li>
    <li><a href="/methodology">Calculator methodology</a></li>
  </ul>
</BaseLayout>
